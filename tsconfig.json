{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2015",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./public/dist",
    "rootDir": "./public",
    "strict": false,
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler"
  },
  "include": ["public/scripts/**/*", "public/scripts/data/**/*", "public/scripts/webComponents/**/*"],
  "exclude": ["node_modules", "public/scripts/test/**/*"]
}
