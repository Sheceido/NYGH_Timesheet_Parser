# Node.js dependencies
node_modules/

# TypeScript compiled output (your build step outputs .js files to public/dist/)
public/dist/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS metadata
.DS_Store
Thumbs.db

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary / scratch files (you have tmp.md in your tree)
*.tmp
tmp.md

# Environment files
.env
.env.local
.env.*.local

# Test coverage
coverage/
.nyc_output/

# Optional: if you use a bundler's cache
.parcel-cache/
.cache/
